# Server
PORT=4001
NODE_ENV=development
# SQLite path (Docker uses /data/pos-local.db via compose)
# DB_PATH=/data/pos-local.db

# --- VPS central hub (on hosted server) ---
POS_MODE=central
SYNC_API_KEY=change-me-use-a-long-random-secret

# --- Local shop PC (offline + sync to VPS) ---
# POS_MODE=shop
# VPS_API_URL=http://84.247.176.143:2633/api
# SHOP_CLIENT_CODE=KENN1927
# SYNC_API_KEY=same-secret-as-vps

# --- Platform M-Pesa (VPS only) — one callback URL for all shops ---
# Per-shop Daraja keys are stored in the database (Client Management → M-Pesa setup).
MPESA_CALLBACK_URL=http://84.247.176.143:2633/api/mpesa/callback
MPESA_ENCRYPTION_KEY=change-me-long-random-key-for-encrypting-shop-secrets

# Legacy global keys (optional fallback — prefer per-shop DB settings)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_ENV=sandbox
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=
